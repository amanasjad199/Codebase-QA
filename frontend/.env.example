# Production / preview: the full origin of your deployed FastAPI backend.
# Example: https://codebaseqa-api.onrender.com
VITE_API_URL=

# Local dev only: where `vite dev` proxies /api requests.
# Leave VITE_API_URL empty in dev so the proxy below is used (no CORS issues).
VITE_DEV_BACKEND=http://127.0.0.1:8000
